# feedbackmonk P0 environment variables.
#
# Copy to `.env` and fill in dev values. Production reads the same names from
# the deploy environment (no .env file loading expected outside dev).
#
# Alphabetical (per GUIDE §6 .env.example sort discipline).

# Postgres connection. Local dev container runs on port 5433; see
# docs/operations/LOCAL_DEV.md.
DATABASE_URL=postgres://postgres:dev@localhost:5433/feedbackmonk_dev

# ---- CLAUDE-A (signup / onboarding) -----------------------------------------

# Per-(anon_hash, project) hourly submissions cap for anonymous mode
# (FR-FBR-06). Default 10; raise for high-traffic projects (P3 will gate
# raises by tier). Integer >= 1.
FEEDBACKMONK_ANON_RATE_LIMIT_PER_HOUR=10

# Admin login (POST /api/v1/login) attempts per minute, per (client IP, email)
# (DEC-FBR-IMPL-10). Checked before the argon2 verify — caps brute-force AND
# the argon2 CPU-DoS vector. Default 10; a human login needs 1–2. Integer >= 1.
FEEDBACKMONK_LOGIN_RATE_LIMIT_PER_MIN=10

# Mailer selection: `mailpit` (dev, no auth, localhost:1025) or `smtp`
# (prod, uses FEEDBACKMONK_SMTP_*).
FEEDBACKMONK_MAILER=mailpit

# Mailpit dev container host/port.
FEEDBACKMONK_MAILPIT_HOST=localhost
FEEDBACKMONK_MAILPIT_PORT=1025

# Operator bearer token for PATCH /api/v1/ops/tenants/{id} (set tier + per-tenant
# widget brand override; DEC-FBR-IMPL-11). Operator-only, never tenant-self-serve.
# Unset = ops endpoint DISABLED (404). Generate via: openssl rand -hex 32
#FEEDBACKMONK_OPS_TOKEN=

# Backend bind port.
FEEDBACKMONK_PORT=14304

# Customer-facing base URL used in verify-email links. No trailing slash.
FEEDBACKMONK_PUBLIC_URL=http://localhost:14304

# HMAC key for signed admin-session cookies. 64 hex chars (32 bytes).
# Generate via:  openssl rand -hex 32
FEEDBACKMONK_SESSION_SECRET=replace-with-64-hex-chars-from-openssl-rand-hex-32-please

# Production SMTP (only required when FEEDBACKMONK_MAILER=smtp).
FEEDBACKMONK_SMTP_FROM=no-reply@feedbackmonk.local
FEEDBACKMONK_SMTP_HOST=smtp.example.com
FEEDBACKMONK_SMTP_PASS=replace-with-smtp-password
FEEDBACKMONK_SMTP_PORT=587
FEEDBACKMONK_SMTP_STARTTLS=true
FEEDBACKMONK_SMTP_USER=feedbackmonk@example.com

# TTL (hours) for verify-email tokens.
FEEDBACKMONK_VERIFY_TOKEN_TTL_HOURS=24

# ---- CLAUDE-B (submission path) ---------------------------------------------

# Clock-skew tolerance (seconds) for the JWT `iat` claim ONLY. `exp` is
# strict per Contract C2 invariant 5 -- this leeway does NOT apply to exp.
FEEDBACKMONK_JWT_LEEWAY_SECONDS=5

# ---- Logging ----------------------------------------------------------------

# `text` for local dev (human-readable); `json` for production (structured
# stdout). Anything else falls back to `json`. Source: SELFHOST_ENV.md.
FEEDBACKMONK_LOG_FORMAT=text

# tracing-subscriber EnvFilter directive. Common values: `info`,
# `feedbackmonk=debug,info`, `warn`. Source: SELFHOST_ENV.md.
RUST_LOG=info
