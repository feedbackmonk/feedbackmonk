{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, tenant_id, project_id, slug, title, body, status,\n                   origin_feedback_id, created_at, created_by, updated_at\n            FROM roadmap_items\n            WHERE tenant_id = $1\n              AND project_id = $2\n              AND ($3::text IS NULL OR status = $3)\n            ORDER BY created_at DESC\n            LIMIT $4\n            OFFSET $5\n            ",
