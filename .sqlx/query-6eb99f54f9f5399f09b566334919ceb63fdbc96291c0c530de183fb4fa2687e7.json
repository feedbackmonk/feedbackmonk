{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT r.id, r.feedback_id, r.body, r.visibility,\n                   r.author_user_id, r.created_at\n            FROM feedback_replies AS r\n            JOIN feedback AS f ON f.id = r.feedback_id\n            WHERE f.tenant_id = $1\n              AND f.project_id = $2\n              AND f.short_code = $3\n            ORDER BY r.created_at ASC\n            ",
