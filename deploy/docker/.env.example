# feedbackmonk self-host .env template (operator-facing).
#
# Copy this file to `.env` and fill in the three REQUIRED values at the
# top, then `docker compose up -d`. Optional vars below have sensible
# defaults — uncomment only to override.
#
# Full env-var documentation: docs/operations/SELFHOST_ENV.md (Contract C21).
# Quick reference also in docs/operations/SELFHOST.md.
#
# This file is operator-facing and intentionally DISTINCT from the
# workspace-root `.env.example` (which is developer-machine-shaped: it
# talks to localhost:5433 and assumes `cargo run`). This file's defaults
# work inside the docker-compose network (db service hostname = `db`).

# =============================================================================
# REQUIRED — set these three or `docker compose up` will fail fast.
# =============================================================================

# Postgres connection string the api binary uses to reach the db service.
# `db` is the in-network hostname of the postgres container. Change the
# password (and ideally also the user + dbname) before `up`.
DATABASE_URL=postgres://feedbackmonk:CHANGE-ME-IN-PRODUCTION@db:5432/feedbackmonk

# Customer-facing base URL. MUST match the URL operators (and feedback
# email recipients) actually visit. No trailing slash. Scheme included.
# Examples:
#   FEEDBACKMONK_PUBLIC_URL=https://feedback.example.com
#   FEEDBACKMONK_PUBLIC_URL=http://localhost:14304   (local self-host)
FEEDBACKMONK_PUBLIC_URL=http://localhost:14304

# HMAC key for signed admin-session cookies. 64 hex chars (32 bytes).
# Generate with: openssl rand -hex 32
# Rotating this invalidates all existing admin sessions.
FEEDBACKMONK_SESSION_SECRET=replace-with-64-hex-chars-from-openssl-rand-hex-32-please

# =============================================================================
# POSTGRES CONTAINER (postgres image init protocol — NOT app-side C21 vars).
# These configure the `db` service's first-boot initialization. Keep them
# in sync with the user/password/dbname inside DATABASE_URL above.
# =============================================================================

POSTGRES_USER=feedbackmonk
POSTGRES_PASSWORD=CHANGE-ME-IN-PRODUCTION
POSTGRES_DB=feedbackmonk

# =============================================================================
# HTTP / port — defaults work for most operators.
# =============================================================================

# The api binary's internal bind port (also the operator-visible host port
# that the admin-ui nginx is exposed at via the compose port mapping).
#FEEDBACKMONK_PORT=14304

# IP address the api binary binds to. In docker-compose this is `0.0.0.0`
# (default below) so the admin-ui edge container can reach api over the
# docker bridge network. Native (non-docker) deployments may prefer
# `127.0.0.1` (loopback only). Source: SELFHOST_ENV.md.
#FEEDBACKMONK_BIND_ADDR=0.0.0.0

# =============================================================================
# Logging — defaults are production-shaped (structured json).
# =============================================================================

# `json` (production default — structured stdout) or `text` (human-readable).
#FEEDBACKMONK_LOG_FORMAT=json

# tracing EnvFilter directive. Examples:
#   info                                       (default)
#   feedbackmonk=debug,info                    (scope debug to feedbackmonk crates)
#   warn                                       (quiet)
#RUST_LOG=info

# =============================================================================
# Sessions & tokens — defaults are spec-conformant.
# =============================================================================

# TTL for verify-email tokens minted at signup. Integer hours, >= 1.
#FEEDBACKMONK_VERIFY_TOKEN_TTL_HOURS=24

# JWT `iat` clock-skew tolerance (seconds). `exp` is strict per Contract C2.
#FEEDBACKMONK_JWT_LEEWAY_SECONDS=5

# =============================================================================
# Anonymous mode rate limit (per (anon_hash, project), per hour).
# =============================================================================

# Integer >= 1. Higher = more permissive; lower = stricter.
# P3 tier enforcement raises this per tier — this is the floor (Free tier).
#FEEDBACKMONK_ANON_RATE_LIMIT_PER_HOUR=10

# =============================================================================
# CORS — browser origins allowed to embed the widget cross-origin.
# =============================================================================

# Comma-separated allowlist of origins (scheme + host + optional port, NO
# trailing slash) permitted to call the public widget endpoints (feedback
# submission + attachment upload) from a browser. Unset/empty = no cross-origin
# embed allowed (secure default). Set this to every site that embeds the widget.
# Not needed for same-origin or native (non-browser) clients.
# Examples:
#   FEEDBACKMONK_CORS_ORIGINS=https://gitcellar.com
#   FEEDBACKMONK_CORS_ORIGINS=https://gitcellar.com,https://www.gitcellar.com
#FEEDBACKMONK_CORS_ORIGINS=

# =============================================================================
# Email delivery.
# =============================================================================

# `mailpit` (dev, talks to the mailpit dev-profile container at mailpit:1025)
# or `smtp` (production, uses FEEDBACKMONK_SMTP_* below).
#FEEDBACKMONK_MAILER=mailpit

# Visible `From:` on outgoing emails. Override for your domain.
#FEEDBACKMONK_SMTP_FROM=no-reply@feedbackmonk.local

# --- Mailpit dev profile (only used if FEEDBACKMONK_MAILER=mailpit) ---
#FEEDBACKMONK_MAILPIT_HOST=mailpit
#FEEDBACKMONK_MAILPIT_PORT=1025

# --- Production SMTP (only used if FEEDBACKMONK_MAILER=smtp) ----------
# Required when MAILER=smtp:
#FEEDBACKMONK_SMTP_HOST=smtp.example.com
#FEEDBACKMONK_SMTP_USER=feedbackmonk@example.com
#FEEDBACKMONK_SMTP_PASS=replace-with-smtp-password
# Optional (sensible defaults):
#FEEDBACKMONK_SMTP_PORT=587
#FEEDBACKMONK_SMTP_STARTTLS=true
