---
import BaseLayout from '../../layouts/BaseLayout.astro';

const sections = [
  {
    href: '/docs/widget',
    title: 'Widget embed',
    summary:
      'Drop the 17 KB script onto your site. Anonymous-by-default with optional JWT identity. No third-party fetches.',
  },
  {
    href: '/docs/api',
    title: 'API reference',
    summary:
      'Public endpoints: submit feedback, fetch widget config, query the public roadmap, vote and promote. JWT semantics.',
  },
  {
    href: '/docs/self-host',
    title: 'Self-host runbook',
    summary:
      '`docker compose up` quickstart, environment-variable reference, backup and restore, upgrade procedure.',
  },
];
---

<BaseLayout
  title="Docs"
  description="feedbackmonk documentation — widget embed, public API, and self-host runbook."
>
  <header class="page-header">
    <h1>Docs</h1>
    <p class="lede">
      Three reference surfaces. Pick the one that matches what you&apos;re
      building.
    </p>
  </header>

  <ul class="doc-list" aria-label="Documentation sections">
    {sections.map((s) => (
      <li class="doc-card">
        <h2><a href={s.href}>{s.title}</a></h2>
        <p>{s.summary}</p>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .page-header { margin-block: 2rem 1.5rem; }
  .doc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1rem;
  }
  .doc-card {
    background: var(--brand-cream);
    border: 1px solid var(--brand-rule);
    border-radius: var(--brand-radius);
    padding: 1.25rem;
  }
  .doc-card h2 {
    font-size: 1.125rem;
    margin: 0 0 0.5rem;
  }
  .doc-card h2 a {
    color: var(--brand-ink);
    text-decoration: none;
  }
  .doc-card h2 a:hover,
  .doc-card h2 a:focus-visible {
    color: var(--brand-sage-deep);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  .doc-card p {
    margin: 0;
    color: var(--brand-muted);
    font-size: 0.9375rem;
  }
</style>
